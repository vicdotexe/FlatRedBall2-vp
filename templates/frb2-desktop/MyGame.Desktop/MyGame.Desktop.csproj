<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RollForward>Major</RollForward>
    <PublishReadyToRun>false</PublishReadyToRun>
    <TieredCompilation>false</TieredCompilation>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>MyGame</RootNamespace>
    <MonoGamePlatform>DesktopGL</MonoGamePlatform>
  </PropertyGroup>

  <!-- Apos.Shapes is intentionally NOT pinned here. Its version flows transitively from
       FlatRedBall2.MonoGame (see $(AposShapesVersion) in the engine's AposShapes.props).
       Precompiled apos-shapes.xnb is wired by templates/build/AposShapesPrecompiled.props. -->
  <ItemGroup>
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1" />
    <PackageReference Include="MonoGame.Content.Builder.Task" Version="3.8.4.1" />
  </ItemGroup>

  <Import Project="..\build\AposShapesPrecompiled.props" />

  <ItemGroup>
    <ProjectReference Include="..\MyGame.Common\MyGame.Common.csproj" />
  </ItemGroup>

  <!-- Link Common's raw runtime-loaded assets (achx, tmx, tsx, json, png) into the
       Desktop output's Content/ folder. Content.mgcb is handled by MonoGame.Content.Builder.Task. -->
  <ItemGroup>
    <Content Include="..\MyGame.Common\Content\**\*.*"
             Exclude="..\MyGame.Common\Content\**\*.mgcb;..\MyGame.Common\Content\bin\**;..\MyGame.Common\Content\obj\**"
             Link="Content\%(RecursiveDir)%(Filename)%(Extension)"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
