<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnimationEditor.App.App"
             RequestedThemeVariant="Dark">
             <!-- "Dark" is required so selection highlights and other controls are visible against the app's dark backgrounds. -->

    <Application.Styles>
        <FluentTheme />
        <!-- Compact buttons: override FluentTheme MinHeight so small +/- buttons aren't stretched -->
        <Style Selector="Button.compact">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Application.Styles>
</Application>