<?xml version="1.0" encoding="utf-8"?>
<BehaviorSave xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name>ToastBehavior</Name>
  <RequiredVariables>
    <Name />
  </RequiredVariables>
  <RequiredInstances>
    <InstanceSave Name="TextInstance" BaseType="Text">
      <Behaviors />
    </InstanceSave>
  </RequiredInstances>
  <RequiredAnimations />
  <DefaultImplementation>Controls/Toast</DefaultImplementation>
</BehaviorSave>